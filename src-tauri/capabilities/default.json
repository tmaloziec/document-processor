{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema.json",
  "identifier": "default",
  "description": "Default capabilities for Document Processor",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:webview:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "dialog:allow-confirm",
    "fs:default",
    "fs:allow-read",
    "fs:allow-write",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-copy-file",
    "fs:allow-read-dir",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "shell:default",
    {
      "identifier": "shell:allow-open",
      "allow": [
        { "path": "/**", "cmd": "xdg-open" },
        { "path": "/home/**" },
        { "path": "/tmp/**" },
        { "url": "https://**" },
        { "url": "http://**" },
        { "url": "file://**" }
      ]
    }
  ]
}
